# nginx module config — XRootD stream module + Prometheus metrics HTTP module
# Requires: --with-stream
# Uses OpenSSL (via -lssl -lcrypto) for GSI x509 authentication
# VOMS support: loaded at runtime via dlopen(libvomsapi.so.1) — no compile-time
# link needed.  Install voms-libs on EL9 to enable VO ACL enforcement.

ngx_addon_name=ngx_stream_xrootd_module

ngx_xrootd_stream_deps="$ngx_addon_dir/src/ngx_xrootd_module.h \
                        $ngx_addon_dir/src/ngx_xrootd_cms_heartbeat.h \
                        $ngx_addon_dir/src/ngx_xrootd_metrics.h \
                        $ngx_addon_dir/src/xrootd_protocol.h"
ngx_xrootd_metrics_deps="$ngx_addon_dir/src/ngx_xrootd_metrics.h"
ngx_xrootd_webdav_deps="$ngx_addon_dir/src/ngx_http_xrootd_webdav_module.h"

# Build both the stream module and the companion HTTP metrics module
ngx_module_type=STREAM
ngx_module_name=ngx_stream_xrootd_module
ngx_module_srcs="$ngx_addon_dir/src/ngx_stream_xrootd_module.c \
                 $ngx_addon_dir/src/ngx_xrootd_config.c \
                 $ngx_addon_dir/src/ngx_xrootd_connection.c \
                 $ngx_addon_dir/src/ngx_xrootd_handshake.c \
                 $ngx_addon_dir/src/ngx_xrootd_session.c \
                 $ngx_addon_dir/src/ngx_xrootd_gsi.c \
                 $ngx_addon_dir/src/ngx_xrootd_token.c \
                 $ngx_addon_dir/src/ngx_xrootd_read_handlers.c \
                 $ngx_addon_dir/src/ngx_xrootd_query.c \
                 $ngx_addon_dir/src/ngx_xrootd_fattr.c \
                 $ngx_addon_dir/src/ngx_xrootd_dirlist.c \
                 $ngx_addon_dir/src/ngx_xrootd_write_handlers.c \
                 $ngx_addon_dir/src/ngx_xrootd_aio.c \
                 $ngx_addon_dir/src/ngx_xrootd_response.c \
                 $ngx_addon_dir/src/ngx_xrootd_path.c \
                 $ngx_addon_dir/src/ngx_xrootd_pki_check.c \
                 $ngx_addon_dir/src/ngx_xrootd_voms.c \
                 $ngx_addon_dir/src/ngx_xrootd_upstream.c \
                 $ngx_addon_dir/src/ngx_xrootd_cms_heartbeat.c"
ngx_module_deps="$ngx_xrootd_stream_deps"
ngx_module_libs="-lssl -lcrypto"
CORE_LIBS="$CORE_LIBS -lssl -lcrypto"
. auto/module

ngx_module_type=HTTP
ngx_module_name=ngx_http_xrootd_metrics_module
ngx_module_srcs="$ngx_addon_dir/src/ngx_http_xrootd_metrics_module.c"
ngx_module_deps="$ngx_xrootd_metrics_deps"
ngx_module_libs=
. auto/module

ngx_module_type=HTTP
ngx_module_name=ngx_http_xrootd_webdav_module
ngx_module_srcs="$ngx_addon_dir/src/ngx_http_xrootd_webdav_module.c \
                 $ngx_addon_dir/src/ngx_http_xrootd_webdav_path.c \
                 $ngx_addon_dir/src/ngx_http_xrootd_webdav_auth.c \
                 $ngx_addon_dir/src/ngx_http_xrootd_webdav_handlers.c \
                 $ngx_addon_dir/src/ngx_http_xrootd_webdav_tpc.c"
ngx_module_deps="$ngx_xrootd_webdav_deps"
ngx_module_libs="-lssl -lcrypto"
. auto/module
